// Finalized accent — indigo. Matches the TWEAK_DEFAULTS the designer shipped
// in the prototype (applied once on mount there). Overrides tokens.styl defaults
// so tokens.styl stays a verbatim copy of the source design system.
:root
  --accent-h: 265
  --accent-c: 0.19

// View Transitions custom animations
@keyframes vt-fade-in
  from
    opacity: 0
  to
    opacity: 1

@keyframes vt-fade-out
  from
    opacity: 1
  to
    opacity: 0

::view-transition-old(root),
::view-transition-new(root)
  animation-duration: calc(500ms * var(--motion, 1))
  animation-timing-function: var(--spring-emphasized, cubic-bezier(0.05, 0.7, 0.1, 1))

::view-transition-old(root)
  animation-name: vt-fade-out

::view-transition-new(root)
  animation-name: vt-fade-in

// Morphing project cards
[style*="view-transition-name: project-"]::view-transition-group,
::view-transition-group(*)
  animation-duration: calc(560ms * var(--motion, 1))
  animation-timing-function: var(--spring-emphasized, cubic-bezier(0.05, 0.7, 0.1, 1))

@keyframes pulse
  0%
    transform: scale(1)
    opacity: 0.5
  70%
    transform: scale(2.4)
    opacity: 0
  100%
    transform: scale(2.4)
    opacity: 0
